{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Pseudoglossa",
  "scopeName": "source.psg",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#program-structure" },
    { "include": "#subprograms" },
    { "include": "#control-keywords" },
    { "include": "#io-keywords" },
    { "include": "#operators" },
    { "include": "#booleans" },
    { "include": "#types" },
    { "include": "#numbers" },
    { "include": "#function-call" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.exclamation.pseudoglossa",
          "match": "!.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.pseudoglossa",
          "begin": "'",
          "end": "'"
        },
        {
          "name": "string.quoted.single.pseudoglossa",
          "begin": "вҖҳ",
          "end": "вҖҷ"
        }
      ]
    },
    "program-structure": {
      "patterns": [
        {
          "name": "keyword.other.program.pseudoglossa",
          "match": "\\b(О ОЎОҹО“ОЎО‘ОңОңО‘|ОӨО•ОӣОҹОЈ_О ОЎОҹО“ОЎО‘ОңОңО‘ОӨОҹОЈ|О‘ОЎО§О—|ОЈОӨО‘ОҳО•ОЎО•ОЈ|ОңО•ОӨО‘О’ОӣО—ОӨО•ОЈ)\\b"
        }
      ]
    },
    "subprograms": {
      "patterns": [
        {
          "name": "keyword.other.subprogram.pseudoglossa",
          "match": "\\b(О”ОҷО‘О”ОҷОҡО‘ОЈОҷО‘|ОӨО•ОӣОҹОЈ_О”ОҷО‘О”ОҷОҡО‘ОЈОҷО‘ОЈ|ОЈОҘОқО‘ОЎОӨО—ОЈО—|ОӨО•ОӣОҹОЈ_ОЈОҘОқО‘ОЎОӨО—ОЈО—ОЈ|ОҡО‘ОӣО•ОЈО•)\\b"
        },
        {
          "name": "entity.name.function.pseudoglossa",
          "match": "(?<=\\b(?:О”ОҷО‘О”ОҷОҡО‘ОЈОҷО‘|ОЈОҘОқО‘ОЎОӨО—ОЈО—|ОҡО‘ОӣО•ОЈО•)\\s)[A-Za-zО‘-О©ОҶОҲОүОҠОҢОҺОҸОұ-ПүО¬ОӯО®ОҜПҢПҚПҺ_][A-Za-zО‘-О©ОҶОҲОүОҠОҢОҺОҸОұ-ПүО¬ОӯО®ОҜПҢПҚПҺ0-9_]*"
        }
      ]
    },
    "control-keywords": {
      "patterns": [
        {
          "name": "keyword.control.conditional.pseudoglossa",
          "match": "\\b(О‘Оқ|ОӨОҹОӨО•|О‘ОӣОӣОҷО©ОЈ|О‘ОӣОӣОҷО©ОЈ_О‘Оқ|ОӨО•ОӣОҹОЈ_О‘Оқ|О•О ОҷОӣО•ОһО•|О О•ОЎОҷО ОӨО©ОЈО—|ОӨО•ОӣОҹОЈ_О•О ОҷОӣОҹО“О©Оқ)\\b"
        },
        {
          "name": "keyword.control.loop.pseudoglossa",
          "match": "\\b(О“ОҷО‘|О‘О Оҹ|ОңО•О§ОЎОҷ|ОңО•|О’О—ОңО‘|ОҹОЈОҹ|О•О О‘ОқО‘ОӣО‘О’О•|О‘ОЎО§О—_О•О О‘ОқО‘ОӣО—ОЁО—ОЈ|ОңО•О§ОЎОҷОЈ_ОҹОӨОҹОҘ|ОӨО•ОӣОҹОЈ_О•О О‘ОқО‘ОӣО—ОЁО—ОЈ)\\b"
        },
        {
          "name": "keyword.control.flow.pseudoglossa",
          "match": "\\b(О•О ОҷОӣО•ОһО•|О О•ОЎОҷО ОӨО©ОЈО—)\\b"
        }
      ]
    },
    "io-keywords": {
      "patterns": [
        {
          "name": "support.function.io.pseudoglossa",
          "match": "\\b(О”ОҷО‘О’О‘ОЈО•|О“ОЎО‘ОЁО•|О“ОЎО‘ОЁО•_)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.word.pseudoglossa",
          "match": "\\b(DIV|MOD|ОҡО‘Оҷ|О—|ОҹО§Оҷ)\\b"
        },
        {
          "name": "keyword.operator.assignment.pseudoglossa",
          "match": "(<--|<-|вҶҗ)"
        },
        {
          "name": "keyword.operator.comparison.pseudoglossa",
          "match": "(<=|>=|<>|=|<|>)"
        },
        {
          "name": "keyword.operator.arithmetic.pseudoglossa",
          "match": "(\\+|-|\\*|/)"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.pseudoglossa",
          "match": "\\b(О‘ОӣО—ОҳО—ОЈ|ОЁО•ОҘО”О—ОЈ)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.pseudoglossa",
          "match": "\\b(О‘ОҡО•ОЎО‘ОҷО‘|О‘ОҡО•ОЎО‘ОҷО•ОЈ|О ОЎО‘О“ОңО‘ОӨОҷОҡО—|О ОЎО‘О“ОңО‘ОӨОҷОҡО•ОЈ|О§О‘ОЎО‘ОҡОӨО—ОЎО‘ОЈ|О§О‘ОЎО‘ОҡОӨО—ОЎО•ОЈ|ОӣОҹО“ОҷОҡО—|ОӣОҹО“ОҷОҡО•ОЈ)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.pseudoglossa",
          "match": "\\b\\d+[\\.,]\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.pseudoglossa",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "support.function.call.pseudoglossa",
          "match": "\\b[A-Za-zО‘-О©ОҶОҲОүОҠОҢОҺОҸОұ-ПүО¬ОӯО®ОҜПҢПҚПҺ_][A-Za-zО‘-О©ОҶОҲОүОҠОҢОҺОҸОұ-ПүО¬ОӯО®ОҜПҢПҚПҺ0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.pseudoglossa",
          "match": "\\b[A-Za-zО‘-О©ОҶОҲОүОҠОҢОҺОҸОұ-ПүО¬ОӯО®ОҜПҢПҚПҺ_][A-Za-zО‘-О©ОҶОҲОүОҠОҢОҺОҸОұ-ПүО¬ОӯО®ОҜПҢПҚПҺ0-9_]*\\b"
        }
      ]
    }
  }
}
