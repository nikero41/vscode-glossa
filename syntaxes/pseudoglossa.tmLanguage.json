{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Pseudoglossa",
	"scopeName": "source.psg",
	"patterns": [
		{ "include": "#comments" },
		{ "include": "#strings" },
		{ "include": "#program-structure" },
		{ "include": "#subprograms" },
		{ "include": "#control-keywords" },
		{ "include": "#enhanced-flow-control" },
		{ "include": "#io-keywords" },
		{ "include": "#operators" },
		{ "include": "#booleans" },
		{ "include": "#types" },
		{ "include": "#numbers" },
		{ "include": "#builtin-functions" },
		{ "include": "#enhanced-functions" },
		{ "include": "#enhanced-screen-execution" },
		{ "include": "#function-call" },
		{ "include": "#punctuation" },
		{ "include": "#identifiers" }
	],
	"repository": {
		"comments": {
			"patterns": [
				{ "name": "comment.line.exclamation.pseudoglossa", "match": "!.*$" }
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.single.pseudoglossa",
					"match": "(')([^'\\n]*)(')",
					"captures": {
						"1": { "name": "punctuation.definition.string.begin.pseudoglossa" },
						"2": { "name": "string.quoted.single.pseudoglossa" },
						"3": { "name": "punctuation.definition.string.end.pseudoglossa" }
					}
				},
				{
					"name": "string.quoted.single.curly.pseudoglossa",
					"match": "(‘)([^’\\n]*)(’)",
					"captures": {
						"1": { "name": "punctuation.definition.string.begin.pseudoglossa" },
						"2": { "name": "string.quoted.single.curly.pseudoglossa" },
						"3": { "name": "punctuation.definition.string.end.pseudoglossa" }
					}
				}
			]
		},
		"program-structure": {
			"patterns": [
				{
					"name": "keyword.other.program.pseudoglossa",
					"match": "\\b(ΠΡΟΓΡΑΜΜΑ|ΤΕΛΟΣ_ΠΡΟΓΡΑΜΜΑΤΟΣ|ΑΡΧΗ|ΣΤΑΘΕΡΕΣ|ΜΕΤΑΒΛΗΤΕΣ)\\b"
				}
			]
		},
		"subprograms": {
			"patterns": [
				{
					"match": "\\b(ΔΙΑΔΙΚΑΣΙΑ)\\s+([A-Za-zΑ-ΩΆΈΉΊΌΎΏα-ωάέήίόύώ_][A-Za-zΑ-ΩΆΈΉΊΌΎΏα-ωάέήίόύώ0-9_]*)(\\s*\\()([^)]*)(\\))",
					"captures": {
						"1": { "name": "keyword.other.subprogram.pseudoglossa" },
						"2": { "name": "entity.name.function.pseudoglossa" },
						"3": { "name": "punctuation.section.group.begin.pseudoglossa" },
						"4": { "name": "variable.parameter.pseudoglossa" },
						"5": { "name": "punctuation.section.group.end.pseudoglossa" }
					}
				},
				{
					"match": "\\b(ΣΥΝΑΡΤΗΣΗ)\\s+([A-Za-zΑ-ΩΆΈΉΊΌΎΏα-ωάέήίόύώ_][A-Za-zΑ-ΩΆΈΉΊΌΎΏα-ωάέήίόύώ0-9_]*)(\\s*\\()([^)]*)(\\))(\\s*:)(\\s*)(ΑΚΕΡΑΙΑ|ΠΡΑΓΜΑΤΙΚΗ|ΧΑΡΑΚΤΗΡΑΣ|ΛΟΓΙΚΗ)",
					"captures": {
						"1": { "name": "keyword.other.subprogram.pseudoglossa" },
						"2": { "name": "entity.name.function.pseudoglossa" },
						"3": { "name": "punctuation.section.group.begin.pseudoglossa" },
						"4": { "name": "variable.parameter.pseudoglossa" },
						"5": { "name": "punctuation.section.group.end.pseudoglossa" },
						"6": { "name": "punctuation.separator.colon.pseudoglossa" },
						"8": { "name": "storage.type.pseudoglossa" }
					}
				},
				{
					"match": "\\b(ΚΑΛΕΣΕ)\\s+([A-Za-zΑ-ΩΆΈΉΊΌΎΏα-ωάέήίόύώ_][A-Za-zΑ-ΩΆΈΉΊΌΎΏα-ωάέήίόύώ0-9_]*)(?=\\s*\\()",
					"captures": {
						"1": { "name": "keyword.other.subprogram.pseudoglossa" },
						"2": { "name": "entity.name.function.call.pseudoglossa" }
					}
				},
				{
					"name": "keyword.other.subprogram.pseudoglossa",
					"match": "\\b(ΤΕΛΟΣ_ΔΙΑΔΙΚΑΣΙΑΣ|ΤΕΛΟΣ_ΣΥΝΑΡΤΗΣΗΣ)\\b"
				}
			]
		},
		"control-keywords": {
			"patterns": [
				{
					"match": "\\b(ΠΕΡΙΠΤΩΣΗ)\\s+(ΑΛΛΙΩΣ)\\b",
					"captures": {
						"1": { "name": "keyword.control.switch.pseudoglossa" },
						"2": { "name": "keyword.control.default.pseudoglossa" }
					}
				},
				{
					"name": "keyword.control.conditional.pseudoglossa",
					"match": "\\b(ΑΝ|ΤΟΤΕ|ΑΛΛΙΩΣ_ΑΝ|ΑΛΛΙΩΣ|ΤΕΛΟΣ_ΑΝ)\\b"
				},
				{
					"name": "keyword.control.loop.pseudoglossa",
					"match": "\\b(ΓΙΑ|ΑΠΟ|ΜΕΧΡΙ|ΜΕ|ΒΗΜΑ|ΟΣΟ|ΕΠΑΝΑΛΑΒΕ|ΑΡΧΗ_ΕΠΑΝΑΛΗΨΗΣ|ΜΕΧΡΙΣ_ΟΤΟΥ|ΤΕΛΟΣ_ΕΠΑΝΑΛΗΨΗΣ)\\b"
				},
				{
					"name": "keyword.control.switch.pseudoglossa",
					"match": "\\b(ΕΠΙΛΕΞΕ|ΠΕΡΙΠΤΩΣΗ|ΤΕΛΟΣ_ΕΠΙΛΟΓΩΝ)\\b"
				}
			]
		},
		"enhanced-flow-control": {
			"patterns": [
				{
					"name": "keyword.control.flow.termination.pseudoglossa",
					"match": "\\b(ΤΕΡΜΑΤΙΣΜΟΣ|ΚΛΕΙΣΕ_ΠΑΡΑΘΥΡΟ|ΕΞΟΔΟΣ)\\b"
				}
			]
		},
		"io-keywords": {
			"patterns": [
				{
					"name": "support.function.io.pseudoglossa",
					"match": "\\b(ΔΙΑΒΑΣΕ|ΓΡΑΨΕ_|ΓΡΑΨΕ)(?![A-Za-zΑ-ΩΆΈΉΊΌΎΏα-ωάέήίόύώ0-9_])"
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.word.pseudoglossa",
					"match": "\\b(DIV|MOD|ΚΑΙ|Η|Ή|ΟΧΙ)\\b"
				},
				{
					"name": "keyword.operator.assignment.pseudoglossa",
					"match": "(<--|<-|←)"
				},
				{ "name": "keyword.operator.range.pseudoglossa", "match": "(\\.\\.)" },
				{
					"name": "keyword.operator.comparison.pseudoglossa",
					"match": "(<=|>=|<>|=|<|>)"
				},
				{
					"name": "keyword.operator.arithmetic.pseudoglossa",
					"match": "(\\+|-|\\*|/|\\^)"
				}
			]
		},
		"booleans": {
			"patterns": [
				{
					"name": "constant.language.boolean.pseudoglossa",
					"match": "\\b(ΑΛΗΘΗΣ|ΨΕΥΔΗΣ)\\b"
				}
			]
		},
		"types": {
			"patterns": [
				{
					"name": "storage.type.pseudoglossa",
					"match": "\\b(ΑΚΕΡΑΙΑ|ΑΚΕΡΑΙΕΣ|ΠΡΑΓΜΑΤΙΚΗ|ΠΡΑΓΜΑΤΙΚΕΣ|ΧΑΡΑΚΤΗΡΑΣ|ΧΑΡΑΚΤΗΡΕΣ|ΛΟΓΙΚΗ|ΛΟΓΙΚΕΣ)\\b"
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.float.pseudoglossa",
					"match": "\\b\\d+\\.\\d+\\b"
				},
				{
					"name": "constant.numeric.integer.pseudoglossa",
					"match": "\\b\\d+\\b"
				}
			]
		},
		"builtin-functions": {
			"patterns": [
				{
					"name": "support.function.builtin.pseudoglossa",
					"match": "\\b(ΗΜ|ΣΥΝ|ΕΦ|Τ_Ρ|Α_Μ|Α_Τ|ΛΟΓ|Ε)\\b(?=\\s*\\()"
				}
			]
		},
		"enhanced-functions": {
			"patterns": [
				{
					"name": "support.function.builtin.pseudoglossa",
					"match": "\\b(ΤΥΧΑΙΟΣ|ΣΤΡΟΓΓ|Κ_Μ)\\b(?=\\s*\\()"
				},
				{
					"name": "support.function.builtin.pseudoglossa",
					"match": "\\b(ΜΗΚΟΣ_ΧΑΡ|ΣΕΙΡΑ_ΧΑΡ|ΧΑΡ)\\b(?=\\s*\\()"
				}
			]
		},
		"enhanced-screen-execution": {
			"patterns": [
				{
					"name": "keyword.control.execution.pseudoglossa",
					"match": "\\b(ΣΕΙΡΙΑΚΗ_ΕΚΤΕΛΕΣΗ|ΠΑΡΑΛΛΗΛΗ_ΕΚΤΕΛΕΣΗ|ΕΚΤΕΛΕΣΕ)\\b"
				},
				{
					"name": "support.function.screen.pseudoglossa",
					"match": "\\b(ΚΑΘΑΡΙΣΕ_ΟΘΟΝΗ|ΠΗΓΑΙΝΕ_ΧΥ)\\b"
				},
				{
					"name": "support.variable.screen.pseudoglossa",
					"match": "\\b(ΘΕΣΗ_Χ|ΘΕΣΗ_Υ)\\b"
				}
			]
		},
		"function-call": {
			"patterns": [
				{
					"name": "entity.name.function.call.pseudoglossa",
					"match": "\\b[A-Za-zΑ-ΩΆΈΉΊΌΎΏα-ωάέήίόύώ_][A-Za-zΑ-ΩΆΈΉΊΌΎΏα-ωάέήίόύώ0-9_]*(?=\\s*\\()"
				}
			]
		},
		"punctuation": {
			"patterns": [
				{
					"name": "punctuation.definition.array.begin.pseudoglossa",
					"match": "\\["
				},
				{
					"name": "punctuation.definition.array.end.pseudoglossa",
					"match": "\\]"
				},
				{
					"name": "punctuation.section.group.begin.pseudoglossa",
					"match": "\\("
				},
				{
					"name": "punctuation.section.group.end.pseudoglossa",
					"match": "\\)"
				},
				{ "name": "punctuation.separator.comma.pseudoglossa", "match": "," },
				{ "name": "punctuation.separator.colon.pseudoglossa", "match": ":" }
			]
		},
		"identifiers": {
			"patterns": [
				{
					"name": "variable.other.pseudoglossa",
					"match": "\\b[A-Za-zΑ-ΩΆΈΉΊΌΎΏα-ωάέήίόύώ_][A-Za-zΑ-ΩΆΈΉΊΌΎΏα-ωάέήίόύώ0-9_]*\\b"
				}
			]
		}
	}
}
