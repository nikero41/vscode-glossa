{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Glossomathia",
	"scopeName": "source.psg",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#program-structure"
		},
		{
			"include": "#subprograms"
		},
		{
			"include": "#control-keywords"
		},
		{
			"include": "#enhanced-flow-control"
		},
		{
			"include": "#io-keywords"
		},
		{
			"include": "#operators"
		},
		{
			"include": "#booleans"
		},
		{
			"include": "#types"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#builtin-functions"
		},
		{
			"include": "#enhanced-functions"
		},
		{
			"include": "#enhanced-screen-execution"
		},
		{
			"include": "#function-call"
		},
		{
			"include": "#punctuation"
		},
		{
			"include": "#identifiers"
		}
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.exclamation.glossomathia",
					"match": "!.*$"
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.single.glossomathia",
					"match": "(')([^'\\n]*)(')",
					"captures": {
						"1": {
							"name": "punctuation.definition.string.begin.glossomathia"
						},
						"2": {
							"name": "string.quoted.single.glossomathia"
						},
						"3": {
							"name": "punctuation.definition.string.end.glossomathia"
						}
					}
				},
				{
					"name": "string.quoted.single.curly.glossomathia",
					"match": "(‘)([^’\\n]*)(’)",
					"captures": {
						"1": {
							"name": "punctuation.definition.string.begin.glossomathia"
						},
						"2": {
							"name": "string.quoted.single.curly.glossomathia"
						},
						"3": {
							"name": "punctuation.definition.string.end.glossomathia"
						}
					}
				}
			]
		},
		"program-structure": {
			"patterns": [
				{
					"name": "keyword.other.program.glossomathia",
					"match": "\\b(ΠΡΟΓΡΑΜΜΑ|ΤΕΛΟΣ_ΠΡΟΓΡΑΜΜΑΤΟΣ|ΑΡΧΗ|ΣΤΑΘΕΡΕΣ|ΜΕΤΑΒΛΗΤΕΣ)\\b"
				}
			]
		},
		"subprograms": {
			"patterns": [
				{
					"match": "\\b(ΔΙΑΔΙΚΑΣΙΑ)\\s+([A-Za-zΑ-ΩΆΈΉΊΌΎΏα-ωάέήίόύώ_][A-Za-zΑ-ΩΆΈΉΊΌΎΏα-ωάέήίόύώ0-9_]*)(\\s*\\()([^)]*)(\\))",
					"captures": {
						"1": {
							"name": "keyword.other.subprogram.glossomathia"
						},
						"2": {
							"name": "entity.name.function.glossomathia"
						},
						"3": {
							"name": "punctuation.section.group.begin.glossomathia"
						},
						"4": {
							"name": "variable.parameter.glossomathia"
						},
						"5": {
							"name": "punctuation.section.group.end.glossomathia"
						}
					}
				},
				{
					"match": "\\b(ΣΥΝΑΡΤΗΣΗ)\\s+([A-Za-zΑ-ΩΆΈΉΊΌΎΏα-ωάέήίόύώ_][A-Za-zΑ-ΩΆΈΉΊΌΎΏα-ωάέήίόύώ0-9_]*)(\\s*\\()([^)]*)(\\))(\\s*:)(\\s*)(ΑΚΕΡΑΙΑ|ΠΡΑΓΜΑΤΙΚΗ|ΧΑΡΑΚΤΗΡΑΣ|ΛΟΓΙΚΗ)",
					"captures": {
						"1": {
							"name": "keyword.other.subprogram.glossomathia"
						},
						"2": {
							"name": "entity.name.function.glossomathia"
						},
						"3": {
							"name": "punctuation.section.group.begin.glossomathia"
						},
						"4": {
							"name": "variable.parameter.glossomathia"
						},
						"5": {
							"name": "punctuation.section.group.end.glossomathia"
						},
						"6": {
							"name": "punctuation.separator.colon.glossomathia"
						},
						"8": {
							"name": "storage.type.glossomathia"
						}
					}
				},
				{
					"match": "\\b(ΚΑΛΕΣΕ)\\s+([A-Za-zΑ-ΩΆΈΉΊΌΎΏα-ωάέήίόύώ_][A-Za-zΑ-ΩΆΈΉΊΌΎΏα-ωάέήίόύώ0-9_]*)(?=\\s*\\()",
					"captures": {
						"1": {
							"name": "keyword.other.subprogram.glossomathia"
						},
						"2": {
							"name": "entity.name.function.call.glossomathia"
						}
					}
				},
				{
					"name": "keyword.other.subprogram.glossomathia",
					"match": "\\b(ΤΕΛΟΣ_ΔΙΑΔΙΚΑΣΙΑΣ|ΤΕΛΟΣ_ΣΥΝΑΡΤΗΣΗΣ)\\b"
				}
			]
		},
		"control-keywords": {
			"patterns": [
				{
					"match": "\\b(ΠΕΡΙΠΤΩΣΗ)\\s+(ΑΛΛΙΩΣ)\\b",
					"captures": {
						"1": {
							"name": "keyword.control.switch.glossomathia"
						},
						"2": {
							"name": "keyword.control.default.glossomathia"
						}
					}
				},
				{
					"name": "keyword.control.conditional.glossomathia",
					"match": "\\b(ΑΝ|ΤΟΤΕ|ΑΛΛΙΩΣ_ΑΝ|ΑΛΛΙΩΣ|ΤΕΛΟΣ_ΑΝ)\\b"
				},
				{
					"name": "keyword.control.loop.glossomathia",
					"match": "\\b(ΓΙΑ|ΑΠΟ|ΜΕΧΡΙ|ΜΕ|ΒΗΜΑ|ΟΣΟ|ΕΠΑΝΑΛΑΒΕ|ΑΡΧΗ_ΕΠΑΝΑΛΗΨΗΣ|ΜΕΧΡΙΣ_ΟΤΟΥ|ΤΕΛΟΣ_ΕΠΑΝΑΛΗΨΗΣ)\\b"
				},
				{
					"name": "keyword.control.switch.glossomathia",
					"match": "\\b(ΕΠΙΛΕΞΕ|ΠΕΡΙΠΤΩΣΗ|ΤΕΛΟΣ_ΕΠΙΛΟΓΩΝ)\\b"
				}
			]
		},
		"enhanced-flow-control": {
			"patterns": [
				{
					"name": "keyword.control.flow.termination.glossomathia",
					"match": "\\b(ΤΕΡΜΑΤΙΣΜΟΣ|ΚΛΕΙΣΕ_ΠΑΡΑΘΥΡΟ|ΕΞΟΔΟΣ)\\b"
				}
			]
		},
		"io-keywords": {
			"patterns": [
				{
					"name": "support.function.io.glossomathia",
					"match": "\\b(ΔΙΑΒΑΣΕ|ΓΡΑΨΕ_|ΓΡΑΨΕ)(?![A-Za-zΑ-ΩΆΈΉΊΌΎΏα-ωάέήίόύώ0-9_])"
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.word.glossomathia",
					"match": "\\b(DIV|MOD|ΚΑΙ|Η|Ή|ΟΧΙ)\\b"
				},
				{
					"name": "keyword.operator.assignment.glossomathia",
					"match": "(<--|<-|←)"
				},
				{
					"name": "keyword.operator.range.glossomathia",
					"match": "(\\.\\.)"
				},
				{
					"name": "keyword.operator.comparison.glossomathia",
					"match": "(<=|>=|<>|=|<|>)"
				},
				{
					"name": "keyword.operator.arithmetic.glossomathia",
					"match": "(\\+|-|\\*|/|\\^)"
				}
			]
		},
		"booleans": {
			"patterns": [
				{
					"name": "constant.language.boolean.glossomathia",
					"match": "\\b(ΑΛΗΘΗΣ|ΨΕΥΔΗΣ)\\b"
				}
			]
		},
		"types": {
			"patterns": [
				{
					"name": "storage.type.glossomathia",
					"match": "\\b(ΑΚΕΡΑΙΑ|ΑΚΕΡΑΙΕΣ|ΠΡΑΓΜΑΤΙΚΗ|ΠΡΑΓΜΑΤΙΚΕΣ|ΧΑΡΑΚΤΗΡΑΣ|ΧΑΡΑΚΤΗΡΕΣ|ΛΟΓΙΚΗ|ΛΟΓΙΚΕΣ)\\b"
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.float.glossomathia",
					"match": "\\b\\d+\\.\\d+\\b"
				},
				{
					"name": "constant.numeric.integer.glossomathia",
					"match": "\\b\\d+\\b"
				}
			]
		},
		"builtin-functions": {
			"patterns": [
				{
					"name": "support.function.builtin.glossomathia",
					"match": "\\b(ΗΜ|ΣΥΝ|ΕΦ|Τ_Ρ|Α_Μ|Α_Τ|ΛΟΓ|Ε)\\b(?=\\s*\\()"
				}
			]
		},
		"enhanced-functions": {
			"patterns": [
				{
					"name": "support.function.builtin.glossomathia",
					"match": "\\b(ΤΥΧΑΙΟΣ|ΣΤΡΟΓΓ|Κ_Μ)\\b(?=\\s*\\()"
				},
				{
					"name": "support.function.builtin.glossomathia",
					"match": "\\b(ΜΗΚΟΣ_ΧΑΡ|ΣΕΙΡΑ_ΧΑΡ|ΧΑΡ)\\b(?=\\s*\\()"
				}
			]
		},
		"enhanced-screen-execution": {
			"patterns": [
				{
					"name": "keyword.control.execution.glossomathia",
					"match": "\\b(ΣΕΙΡΙΑΚΗ_ΕΚΤΕΛΕΣΗ|ΠΑΡΑΛΛΗΛΗ_ΕΚΤΕΛΕΣΗ|ΕΚΤΕΛΕΣΕ)\\b"
				},
				{
					"name": "support.function.screen.glossomathia",
					"match": "\\b(ΚΑΘΑΡΙΣΕ_ΟΘΟΝΗ|ΠΗΓΑΙΝΕ_ΧΥ)\\b"
				},
				{
					"name": "support.variable.screen.glossomathia",
					"match": "\\b(ΘΕΣΗ_Χ|ΘΕΣΗ_Υ)\\b"
				}
			]
		},
		"function-call": {
			"patterns": [
				{
					"name": "entity.name.function.call.glossomathia",
					"match": "\\b[A-Za-zΑ-ΩΆΈΉΊΌΎΏα-ωάέήίόύώ_][A-Za-zΑ-ΩΆΈΉΊΌΎΏα-ωάέήίόύώ0-9_]*(?=\\s*\\()"
				}
			]
		},
		"punctuation": {
			"patterns": [
				{
					"name": "punctuation.definition.array.begin.glossomathia",
					"match": "\\["
				},
				{
					"name": "punctuation.definition.array.end.glossomathia",
					"match": "\\]"
				},
				{
					"name": "punctuation.section.group.begin.glossomathia",
					"match": "\\("
				},
				{
					"name": "punctuation.section.group.end.glossomathia",
					"match": "\\)"
				},
				{
					"name": "punctuation.separator.comma.glossomathia",
					"match": ","
				},
				{
					"name": "punctuation.separator.colon.glossomathia",
					"match": ":"
				}
			]
		},
		"identifiers": {
			"patterns": [
				{
					"name": "variable.other.glossomathia",
					"match": "\\b[A-Za-zΑ-ΩΆΈΉΊΌΎΏα-ωάέήίόύώ_][A-Za-zΑ-ΩΆΈΉΊΌΎΏα-ωάέήίόύώ0-9_]*\\b"
				}
			]
		}
	}
}
