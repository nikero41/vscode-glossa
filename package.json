{
	"name": "pseudoglossa-language-support",
	"displayName": "Pseudoglossa Language Support",
	"description": "",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"lint": "concurrently --group --names oxc,types -c=#ea580c,#307fe2 --success=all \"npm:lint:oxc --silent\" \"npm:lint:ts --silent\"",
		"lint:oxc": "oxlint",
		"lint:ts": "tsc --noEmit",
		"fmt": "oxfmt",
	},
	"engines": {
		"vscode": "^1.120.0"
	},
	"categories": [
		"Programming Languages"
	],
	"contributes": {
		"languages": [
			{
				"id": "pseudoglossa",
				"aliases": [
					"Pseudoglossa",
					"pseudoglossa"
				],
				"extensions": [
					".psg"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "pseudoglossa",
				"scopeName": "source.psg",
				"path": "./syntaxes/pseudoglossa.tmLanguage.json"
			}
		]
	},
	"dependencies": {
		"vscode-textmate": "^9.3.2"
	},
	"devDependencies": {
		"@total-typescript/ts-reset": "^0.6.1",
		"@total-typescript/tsconfig": "^1.0.4",
		"@types/node": "^25.9.3",
		"concurrently": "^10.0.3",
		"eslint-plugin-import-zod": "^1.2.1",
		"oxfmt": "^0.54.0",
		"oxlint": "^1.69.0",
		"oxlint-tsgolint": "^0.23.0",
		"typescript": "^6.0.3",
	},
	"allowScripts": {
		"fsevents@2.3.3": true
	}
}
