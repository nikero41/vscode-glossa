{
	"name": "vscode-glossa",
	"displayName": "Υποστήριξη ΓΛΩΣΣΑΣ",
	"description": "Υποστήριξη για τη γλώσσα ΓΛΩΣΣΑ στο Visual Studio Code, με χρωματισμό σύνταξης.",
	"version": "0.1.0",
	"type": "module",
	"license": "SEE LICENSE IN LICENSE",
	"publisher": "nikero",
	"repository": {
		"type": "git",
		"url": "https://github.com/nikero/vscode-glossa"
	},
	"bugs": {
		"url": "https://github.com/nikero/vscode-glossa/issues"
	},
	"homepage": "https://glossomathia.gr",
	"keywords": [
		"ΓΛΩΣΣΑ",
		"ΓΛΩΣΣΟΜΑΘΕΙΑ",
		"γλωσσομαθεια",
		"γλωσσα",
		"προγραμματισμός"
	],
	"qna": "marketplace",
	"galleryBanner": {
		"color": "#1f2937",
		"theme": "dark"
	},
	"preview": true,
	"main": "./out/src/extension.js",
	"icon": "./assets/logo-small.png",
	"files": [
		"language-configuration.json",
		"syntaxes",
		"README.md",
		"CHANGELOG.md",
		"LICENSE",
		"out/**",
		"assets/**"
	],
	"scripts": {
		"lint": "concurrently --group --names oxc,types -c=#ea580c,#307fe2 --success=all \"npm:lint:oxc --silent\" \"npm:lint:ts --silent\"",
		"lint:oxc": "oxlint",
		"lint:ts": "tsc --noEmit",
		"fmt": "oxfmt",
		"build": "npm run build:grammar && npm run build:extension",
		"test": "npm run test:syntax && npm run test:unit",
		"test:syntax": "npm run build:grammar && vscode-tmgrammar-test \"test/**/*.syntax-test.{psg,glo,gls}\"",
		"test:unit": "vitest run",
		"test:snap": "vscode-tmgrammar-snap \"example_files/**/*.{psg,glo,gls}\"",
		"test:snap:update": "vscode-tmgrammar-snap --updateSnapshot \"example_files/**/*.{psg,glo,gls}\"",
		"build:grammar": "tsx src/generators/textmate/build.ts",
		"build:extension": "tsc",
		"watch": "tsc --watch",
		"vscode:prepublish": "npm run build"
	},
	"engines": {
		"vscode": "^1.125.0"
	},
	"categories": [
		"Programming Languages"
	],
	"contributes": {
		"languages": [
			{
				"id": "glossomathia",
				"aliases": [
					"ΓΛΩΣΣΑ",
					"ΓΛΩΣΣΟΜΑΘΕΙΑ",
					"γλωσσομαθεια",
					"γλωσσα"
				],
				"extensions": [
					".psg",
					".glo",
					".gls"
				],
				"configuration": "./language-configuration.json",
				"icon": {
					"dark": "./assets/logo-small.png",
					"light": "./assets/logo-small.png"
				}
			}
		],
		"grammars": [
			{
				"language": "glossomathia",
				"scopeName": "source.psg",
				"path": "./syntaxes/glossomathia.tmLanguage.json"
			}
		]
	},
	"dependencies": {
		"vscode-textmate": "^9.3.2"
	},
	"devDependencies": {
		"@total-typescript/ts-reset": "^0.6.1",
		"@total-typescript/tsconfig": "^1.0.4",
		"@types/node": "^25.9.3",
		"@types/vscode": "^1.125.0",
		"concurrently": "^10.0.3",
		"eslint-plugin-import-zod": "^1.2.1",
		"oxfmt": "^0.59.0",
		"oxlint": "^1.74.0",
		"oxlint-tsgolint": "^0.25.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.10",
		"vscode-tmgrammar-test": "^0.1.3"
	},
	"allowScripts": {
		"fsevents@2.3.3": true,
		"esbuild@0.28.1": true
	}
}
